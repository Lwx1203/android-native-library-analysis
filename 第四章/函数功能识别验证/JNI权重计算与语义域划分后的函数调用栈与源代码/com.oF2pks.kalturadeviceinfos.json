      "comment_inside": "// NOLINT(hicpp-signed-bitwise)",
      "code": "__unused\nJava_com_oF2pks_kalturadeviceinfos_Collector_get_1binder_1version(JNIEnv *env, jobject instance) {\n#pragma clang diagnostic pop\n    struct binder_version version{};\n    version.protocol_version = -1;\n    int fd;\n    int ret;\n    fd = open(BINDER_PATH, O_CLOEXEC | O_RDWR); // NOLINT(hicpp-signed-bitwise)\n    if (fd < 0) return -errno;\n    ret = ioctl(fd, BINDER_VERSION, &version);\n    close(fd);\n    if (ret < 0) return -abs(ret);\n    return version.protocol_version;\n}",
