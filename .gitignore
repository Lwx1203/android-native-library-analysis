# ==========================================
# 1. 忽略所有隐藏文件与隐藏文件夹
# ==========================================
# 忽略所有以点开头的文件和文件夹
.*
# 但排除 .gitignore 文件自身，保证它能被上传
!.gitignore

# ==========================================
# 2. PyCharm / Python 项目忽略配置
# ==========================================
# 虚拟环境
venv/
env/
.venv/
# 字节码和缓存
__pycache__/
*.py[cod]
*$py.class
# PyCharm 特定配置
.idea/

# ==========================================
# 3. Android Studio 项目忽略配置
# ==========================================
# Gradle 缓存与配置
.gradle/
# 本地 SDK 路径配置（绝对不能上传，会影响他人编译）
local.properties
# 编译生成的构建目录（根目录及所有子模块的 build 目录）
build/
**/build/
# IDE 特定文件
*.iml
.cxx/
.externalNativeBuild/
captures/

# ==========================================
# 4. 操作系统产生的垃圾文件 (例如 macOS / Windows)
# ==========================================
.DS_Store
Thumbs.db